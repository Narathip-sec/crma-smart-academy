# CRMA Smart Academy — env template
# Copy to .env.local for dev; never commit a populated .env.
# Real values land in Phase 2b (LINE channel) / 2c (Brevo SMTP) /
# external provisioning (Supabase, Vercel).

# Prisma (Postgres). Phase 2c will introduce pgcrypto for sensitive
# columns; Phase 2b+ may add a separate direct URL when pgbouncer
# is in front (passed to the @prisma/adapter-pg constructor).
DATABASE_URL="postgresql://user:pass@localhost:5432/crma?schema=public"

# Session JWT signing secret. Must be >= 32 bytes for HS256.
# Generate: `node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"`
JWT_SECRET=""

# LINE Login channel (server-only).
# From LINE Developers Console -> Provider -> LINE Login channel.
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# LINE JWKs endpoint. Override only for tests.
LINE_JWKS_URL="https://api.line.me/oauth2/v2.1/certs"

# LIFF (client-side). Must use NEXT_PUBLIC_ prefix so Next inlines
# it into the browser bundle. Empty in dev = button shows the
# "LIFF not configured" fallback.
NEXT_PUBLIC_LIFF_ID=""
