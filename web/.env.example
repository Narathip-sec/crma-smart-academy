# CRMA Smart Academy — env template.
# Copy to .env.local for dev; never commit a populated .env.
# Production values live in Vercel project settings.
# Each var is consumed at exactly one place — grep for the name to find it.

# =========================
# Database (Phase 2a+)
# =========================
# Supabase Postgres connection string. Region: ap-southeast-1 (Singapore).
# Use the *pooled* connection string for DATABASE_URL (Supabase pooler
# on port 6543) — runtime queries go through @prisma/adapter-pg.
# DIRECT_URL is the unpooled string (port 5432) used only by
# `prisma migrate deploy` at release time.
DATABASE_URL="postgresql://user:pass@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:pass@db.<project>.supabase.co:5432/postgres"

# =========================
# Session / JWT (Phase 2a)
# =========================
# HS256 signing secret. Must be >= 32 bytes.
# Generate: node -e "console.log(require('node:crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=""

# =========================
# Application crypto (Phase 2c)
# =========================
# AES-256-GCM envelope key — exactly 32 bytes, base64url encoded.
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
ENCRYPTION_KEY=""

# HMAC-SHA-256 key for deterministic email lookup hash — >= 32 bytes, base64url.
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
HMAC_KEY=""

# =========================
# LINE Login (Phase 2b)
# =========================
# LINE Developers Console -> Provider -> LINE Login channel.
LINE_CHANNEL_ID=""
LINE_CHANNEL_SECRET=""

# LINE JWKs endpoint. Override only for tests.
LINE_JWKS_URL="https://api.line.me/oauth2/v2.1/certs"

# LIFF client-side ID. NEXT_PUBLIC_ prefix => inlined into browser bundle.
# Empty in dev => LiffSignInButton renders the "LIFF not configured" fallback.
NEXT_PUBLIC_LIFF_ID=""

# =========================
# Email OTP (Phase 2c)
# =========================
# Brevo (formerly Sendinblue) HTTP API key. Empty => OTP printed to
# console (lib/email.ts dev fallback) and route still resolves OK.
BREVO_API_KEY=""

# =========================
# LINE Messaging API (Phase 9)
# =========================
# Messaging API channel access token. Empty => lib/line-messaging.ts
# logs and resolves { ok: true, reason: 'noop:dev_fallback' } so
# /api/cron/duty-reminder works in CI without live LINE creds.
LINE_CHANNEL_ACCESS_TOKEN=""

# Webhook signature channel secret (LINE Developers -> Messaging API
# channel -> Channel secret). Verified by lib/line-webhook.ts via
# HMAC-SHA-256 against x-line-signature. Empty => /api/line/webhook
# returns 503 (not_configured).
#
# NOTE: This is the *Messaging API* channel secret, not the LINE Login
# channel secret above. They are two different channels under the
# same Provider in the LINE Developers Console.
#
# If you reuse the LINE Login channel for webhooks, set this to the
# same value as LINE_CHANNEL_SECRET above.

# =========================
# Cron auth (Phase 9)
# =========================
# Vercel Cron injects `Authorization: Bearer ${CRON_SECRET}` automatically.
# Set this in Vercel project env to anything random and unguessable.
# Generate: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=""
