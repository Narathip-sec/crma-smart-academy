// CRMA Smart Cadet Platform — MVP schema (Phase 3)
// Groups: Identity · Content · Class · Meals · Calendar · Todo · Activity · Report · Lost&Found · Service · System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  cadet
  instructor
  command
  moderator
}

enum ClassCategory {
  academic
  military
  pe
  advisory
  self_study
}

enum CalendarCategory {
  academic
  exam
  military
  activity
  holiday
  deadline
}

enum MealType {
  breakfast
  lunch
  dinner
}

enum ActivityStatus {
  draft
  open
  closed
  cancelled
}

enum ModerationStatus {
  pending
  approved
  rejected
}

enum ReportStatus {
  open
  in_progress
  resolved
  closed
}

enum LostFoundStatus {
  reported
  matched
  claimed
  closed
}

enum NotificationChannel {
  in_app
  line_push
}

// ─── Identity ─────────────────────────────────────────────────────────────────

/// App user — created on first LIFF login or manual provisioning.
model User {
  id          String   @id @default(cuid())
  email       String?  @unique // *@crma.ac.th if known
  displayName String
  avatarUrl   String?
  role        Role     @default(cadet)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cadetProfile         CadetProfile?
  lineAccount          LineAccount?
  roleAssignments      RoleAssignment[]
  notifications        Notification[]
  notificationDeliveries NotificationDelivery[]
  auditLogs            AuditLog[]
  createdActivities    ActivityEvent[]          @relation("ActivityCreator")
  activityAttendees    ActivityAttendee[]
  activityComments     ActivityComment[]
  activityModerations  ActivityModerationLog[]
  reportTickets        ReportTicket[]
  reportStatusEvents   ReportStatusEvent[]
  lostFoundItems       LostFoundItem[]
  lostFoundClaims      LostFoundClaim[]
  lostFoundStatusEvents LostFoundStatusEvent[]
  taskAssignments      TaskAssignment[]
  taskCompletions      TaskCompletion[]
  taskComments         TaskComment[]
}

model CadetProfile {
  id            String @id @default(cuid())
  userId        String @unique
  studentCode   String @unique // "67-0421"
  thaiName      String
  englishName   String
  rank          String // "2LT", "1LT"
  yearLevel     Int    // 1..4 (ชั้นปี)
  companyId     String
  battalion     String // "BN-2"
  yearRank      Int?   // rank within cohort, e.g. 12
  yearRankTotal Int?   // cohort size, e.g. 118

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])
  grades  Grade[]

  @@index([companyId])
}

// ─── Academics ──────────────────────────────────────────────────────────────

model Semester {
  id        String   @id @default(cuid())
  label     String   @unique // "1/2569"
  order     Int      // sort key, higher = more recent
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  grades Grade[]

  @@index([order])
}

model Grade {
  id             String   @id @default(cuid())
  cadetProfileId String
  semesterId     String
  courseCode     String
  courseNameTh   String
  courseNameEn   String?
  credits        Int
  grade          String?  // null = ผลยังไม่ประกาศ (pending)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cadetProfile CadetProfile @relation(fields: [cadetProfileId], references: [id], onDelete: Cascade)
  semester     Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@unique([cadetProfileId, semesterId, courseCode])
  @@index([cadetProfileId])
  @@index([semesterId])
}

model LineAccount {
  id         String   @id @default(cuid())
  userId     String   @unique
  lineUserId String   @unique
  linkedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  grantedAt DateTime @default(now())
  grantedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model Company {
  id           String         @id @default(cuid())
  name         String         @unique // "Co-A"
  cadetProfiles CadetProfile[]
}

// ─── Content ──────────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  titleTh   String
  titleEn   String?
  bodyTh    String
  bodyEn    String?
  pinned    Boolean  @default(false)
  publishAt DateTime @default(now())
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments FileAsset[]
}

model NewsItem {
  id        String   @id @default(cuid())
  titleTh   String
  titleEn   String?
  bodyTh    String
  bodyEn    String?
  imageUrl  String?
  publishAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FileAsset {
  id             String        @id @default(cuid())
  url            String
  mimeType       String
  sizeBytes      Int?
  nameTh         String?
  nameEn         String?
  uploadedAt     DateTime      @default(now())
  announcementId String?
  activityEventId String?
  reportAttachment ReportAttachment?
  lostFoundAttachment LostFoundAttachment?

  announcement   Announcement?  @relation(fields: [announcementId], references: [id])
  activityEvent  ActivityEvent? @relation(fields: [activityEventId], references: [id])
}

// ─── Class ────────────────────────────────────────────────────────────────────

/// Source: schedule.csv (one row per class period, date-based).
model ClassPeriod {
  id          String        @id @default(cuid())
  date        DateTime      @db.Date
  dayTh       String        // "จันทร์"
  periodLabel String        // "1-2"
  startTime   String        // "08:00"
  endTime     String        // "09:50"
  courseCode  String?
  courseName  String
  section     String?
  instructor  String?
  room        String?
  remarks     String?
  category    ClassCategory @default(academic)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([date, periodLabel, courseName])
  @@index([date])
}

// ─── Meals ────────────────────────────────────────────────────────────────────

model MealMonth {
  id           String    @id @default(cuid())
  year         Int       // 2026
  month        Int       // 1-12
  importedAt   DateTime  @default(now())
  sourceFile   String?

  days MealDay[]

  @@unique([year, month])
}

model MealDay {
  id          String    @id @default(cuid())
  mealMonthId String
  date        DateTime  @db.Date

  mealMonth MealMonth  @relation(fields: [mealMonthId], references: [id], onDelete: Cascade)
  items     MealItem[]

  @@unique([mealMonthId, date])
  @@index([date])
}

/// Source: meals CSV (wide→long transform). One row per meal slot per day.
model MealItem {
  id        String   @id @default(cuid())
  mealDayId String?  // null = standalone import (legacy)
  date      DateTime @db.Date
  mealType  MealType
  menuTh    String
  menuEn    String?
  note      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mealDay MealDay? @relation(fields: [mealDayId], references: [id])

  @@unique([date, mealType])
  @@index([date])
}

// ─── Calendar ─────────────────────────────────────────────────────────────────

/// Source: crma_schedule_structured.csv (academic calendar, one row per event).
model AcademicCalendarEvent {
  id            String           @id @default(cuid())
  academicYear  Int              // พ.ศ.
  date          DateTime         @db.Date
  thaiDateLabel String?
  dayOfWeekTh   String?
  startTime     String?
  endTime       String?
  titleTh       String
  titleEn       String?
  category      CalendarCategory @default(academic)
  note          String?
  sourcePage    Int?
  sourceRow     Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([academicYear, date, titleTh])
  @@index([academicYear, date])
  @@index([academicYear, category])
}

// ─── Todo ─────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @default(cuid())
  titleTh     String
  titleEn     String?
  descriptionTh String?
  descriptionEn String?
  dueAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignments TaskAssignment[]
  completions TaskCompletion[]
  comments    TaskComment[]
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  completedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  bodyTh    String
  bodyEn    String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Activity ─────────────────────────────────────────────────────────────────

model ActivityCategory {
  id      String          @id @default(cuid())
  nameTh  String          @unique
  nameEn  String?
  iconKey String?

  events ActivityEvent[]
}

model ActivityEvent {
  id            String         @id @default(cuid())
  categoryId    String?
  creatorId     String
  titleTh       String
  titleEn       String?
  descriptionTh String?
  descriptionEn String?
  location      String?
  startAt       DateTime
  endAt         DateTime?
  maxAttendees  Int?
  status        ActivityStatus @default(draft)
  modStatus     ModerationStatus @default(pending)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  category    ActivityCategory?       @relation(fields: [categoryId], references: [id])
  creator     User                    @relation("ActivityCreator", fields: [creatorId], references: [id])
  attendees   ActivityAttendee[]
  comments    ActivityComment[]
  moderations ActivityModerationLog[]
  images      FileAsset[]
}

model ActivityAttendee {
  id           String   @id @default(cuid())
  activityId   String
  userId       String
  registeredAt DateTime @default(now())
  attended     Boolean  @default(false)

  activity ActivityEvent @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([activityId, userId])
}

model ActivityComment {
  id         String   @id @default(cuid())
  activityId String
  userId     String
  bodyTh     String
  bodyEn     String?
  createdAt  DateTime @default(now())

  activity ActivityEvent @relation(fields: [activityId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityModerationLog {
  id         String           @id @default(cuid())
  activityId String
  moderatorId String
  action     String           // "approve" | "reject" | "flag"
  reason     String?
  createdAt  DateTime         @default(now())

  activity  ActivityEvent @relation(fields: [activityId], references: [id], onDelete: Cascade)
  moderator User          @relation(fields: [moderatorId], references: [id])
}

// ─── Report ───────────────────────────────────────────────────────────────────

model ReportCategory {
  id      String         @id @default(cuid())
  nameTh  String         @unique
  nameEn  String?
  iconKey String?

  tickets ReportTicket[]
}

model MaintenanceTeam {
  id      String         @id @default(cuid())
  nameTh  String         @unique
  nameEn  String?

  tickets ReportTicket[]
}

model ReportTicket {
  id          String       @id @default(cuid())
  ticketNo    String       @unique // "RPT-2026-0001"
  reporterId  String
  categoryId  String?
  teamId      String?
  titleTh     String
  descriptionTh String
  locationId  String?
  status      ReportStatus @default(open)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reporter    User              @relation(fields: [reporterId], references: [id])
  category    ReportCategory?   @relation(fields: [categoryId], references: [id])
  team        MaintenanceTeam?  @relation(fields: [teamId], references: [id])
  location    ReportLocation?   @relation(fields: [locationId], references: [id])
  attachments ReportAttachment[]
  statusEvents ReportStatusEvent[]

  @@index([reporterId])
  @@index([status])
}

model ReportLocation {
  id       String  @id @default(cuid())
  nameTh   String
  lat      Float?
  lng      Float?
  mapPin   String? // serialized pin JSON

  tickets ReportTicket[]
}

model ReportAttachment {
  id       String @id @default(cuid())
  ticketId String
  assetId  String @unique

  ticket ReportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  asset  FileAsset    @relation(fields: [assetId], references: [id])
}

model ReportStatusEvent {
  id        String       @id @default(cuid())
  ticketId  String
  actorId   String
  fromStatus ReportStatus?
  toStatus  ReportStatus
  note      String?
  createdAt DateTime     @default(now())

  ticket ReportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User         @relation(fields: [actorId], references: [id])
}

// ─── Lost & Found ─────────────────────────────────────────────────────────────

model LostFoundCategory {
  id      String          @id @default(cuid())
  nameTh  String          @unique
  nameEn  String?
  iconKey String?

  items LostFoundItem[]
}

model LostFoundItem {
  id           String          @id @default(cuid())
  reporterId   String
  categoryId   String?
  titleTh      String
  descriptionTh String
  foundAt      DateTime?       @db.Date
  foundLocation String?
  status       LostFoundStatus @default(reported)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  reporter    User                  @relation(fields: [reporterId], references: [id])
  category    LostFoundCategory?    @relation(fields: [categoryId], references: [id])
  claims      LostFoundClaim[]
  attachments LostFoundAttachment[]
  statusEvents LostFoundStatusEvent[]

  @@index([status])
}

model LostFoundClaim {
  id        String   @id @default(cuid())
  itemId    String
  claimantId String
  note      String?
  claimedAt DateTime @default(now())

  item     LostFoundItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  claimant User          @relation(fields: [claimantId], references: [id])

  @@unique([itemId, claimantId])
}

model LostFoundAttachment {
  id      String @id @default(cuid())
  itemId  String
  assetId String @unique

  item  LostFoundItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  asset FileAsset     @relation(fields: [assetId], references: [id])
}

model LostFoundStatusEvent {
  id         String          @id @default(cuid())
  itemId     String
  actorId    String
  fromStatus LostFoundStatus?
  toStatus   LostFoundStatus
  note       String?
  createdAt  DateTime        @default(now())

  item  LostFoundItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  actor User          @relation(fields: [actorId], references: [id])
}

// ─── Service ──────────────────────────────────────────────────────────────────

model ServiceCategory {
  id      String        @id @default(cuid())
  nameTh  String        @unique
  nameEn  String?
  iconKey String?
  sortOrder Int         @default(0)

  items ServiceItem[]
}

model ServiceItem {
  id          String  @id @default(cuid())
  categoryId  String
  nameTh      String
  nameEn      String?
  descriptionTh String?
  url         String? // external link or deep link
  iconKey     String?
  sortOrder   Int     @default(0)
  active      Boolean @default(true)

  category ServiceCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
}

// ─── System ───────────────────────────────────────────────────────────────────

model Notification {
  id         String              @id @default(cuid())
  userId     String
  titleTh    String
  bodyTh     String
  deepLink   String?
  readAt     DateTime?
  createdAt  DateTime            @default(now())

  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, readAt])
}

model NotificationDelivery {
  id             String              @id @default(cuid())
  notificationId String
  userId         String
  channel        NotificationChannel
  deliveredAt    DateTime?
  failReason     String?
  createdAt      DateTime            @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, channel])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String   // "report.create" | "claim.approve" etc.
  entityType String? // "ReportTicket" | "LostFoundItem"
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
