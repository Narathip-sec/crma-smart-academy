// CRMA Smart Academy — Prisma schema
// Phase 2a: User + Role + RefreshToken + AuditLog (auth foundation).
// URL is configured in prisma.config.ts; runtime uses @prisma/adapter-pg.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =========================
// Auth / users (Phase 2a)
// =========================

/// Cadet, instructor, officer, or admin.
/// Phase 2c splits the email column into two:
///   - emailHash: HMAC-SHA-256(normalisedEmail) using HMAC_KEY env.
///     Unique-indexed so we can look up by email without storing
///     plaintext. Deterministic per key.
///   - emailCiphertext: AES-256-GCM envelope of the verified email
///     using ENCRYPTION_KEY. Nullable until Phase 2c verify completes.
/// Both columns are managed by `lib/crypto.ts`. Pre-verify a user
/// row carries a placeholder hash derived from the lineUserId.
model User {
  id              String    @id @default(cuid())
  cadetId         String    @unique
  emailHash       String    @unique
  emailCiphertext String?
  emailVerified   DateTime?
  lineUserId      String?   @unique
  displayName     String
  avatarUrl       String?
  role            Role      @default(CADET)
  company         String?
  year            Int?
  /// AES-256-GCM ciphertext of the TOTP secret (via lib/crypto.encrypt).
  /// Plaintext base32 never persisted. Nullable until /enrol/totp/start
  /// generates the secret.
  totpSecret      String?
  /// Stamped by /enrol/totp/verify after the first valid 6-digit code.
  /// LINE callback gates `needs_totp` on this field — NOT on totpSecret
  /// presence — so a half-enrolled cadet whose /start ran but /verify
  /// did not is still routed to needs_totp on the next sign-in.
  totpVerified    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  emailOtps     EmailOtp[]

  @@index([role])
}

enum Role {
  CADET
  INSTRUCTOR
  OFFICER
  ADMIN
}

/// One row per active session per device. tokenHash is sha256(refreshJwt) — never raw token.
/// deviceFp gates TOTP re-prompt on new device (Phase 2d).
model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  deviceFp   String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([tokenHash])
}

/// Append-only audit trail. Every API mutation writes one row.
/// Partitioning + cold-storage rotation is a Phase 10 hardening task.
model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String
  result    AuditResult @default(ALLOW)
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([resource, createdAt])
  @@index([action, createdAt])
}

enum AuditResult {
  ALLOW
  DENY
  ERROR
}

/// 6-digit numeric OTP issued for institutional email verification.
/// codeHash = sha256(code); the plaintext code is never persisted.
/// emailHash binds the OTP to the specific email the cadet entered
/// so a re-request with a different email starts a new row.
/// emailCiphertext = AES-GCM envelope of the plaintext email. /start
/// computes it once and persists it here so /verify can copy it to
/// User.emailCiphertext without re-prompting the cadet for the address.
model EmailOtp {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash        String
  emailHash       String
  emailCiphertext String
  expiresAt       DateTime
  attempts        Int       @default(0)
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([emailHash, createdAt])
}
